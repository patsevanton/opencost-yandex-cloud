{
 "__inputs": [],
 "__requires": [
  {
   "type": "grafana",
   "id": "grafana",
   "name": "Grafana",
   "version": "10.4.2"
  },
  {
   "type": "datasource",
   "id": "prometheus",
   "name": "Prometheus",
   "version": "1.0.0"
  }
 ],
 "annotations": {
  "list": [
   {
    "builtIn": 1,
    "datasource": { "type": "grafana", "uid": "-- Grafana --" },
    "enable": true,
    "hide": true,
    "name": "Annotations & Alerts",
    "type": "dashboard"
   }
  ]
 },
 "editable": true,
 "fiscalYearStartMonth": 0,
 "graphTooltip": 0,
 "id": null,
 "links": [],
 "description": "Стоимость сети (egress, NAT) и Load Balancer по данным OpenCost.",
 "panels": [
  {
   "collapsed": false,
   "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
   "id": 1,
   "title": "Network Egress (cost per GiB)",
   "type": "row"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
   "id": 2,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_network_zone_egress_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "Zone Egress (₽/GiB)",
   "description": "Стоимость за GiB egress в зоне.",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
   "id": 3,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_network_region_egress_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "Region Egress (₽/GiB)",
   "description": "Стоимость за GiB egress в регионе.",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
   "id": 4,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_network_internet_egress_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "Internet Egress (₽/GiB)",
   "description": "Стоимость за GiB egress в интернет.",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
   "id": 5,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_network_nat_gateway_egress_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "NAT Gateway Egress (₽/GiB)",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
   "id": 6,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_network_nat_gateway_ingress_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "NAT Gateway Ingress (₽/GiB)",
   "type": "stat"
  },
  {
   "collapsed": false,
   "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
   "id": 7,
   "title": "Load Balancer",
   "type": "row"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
   "id": 8,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_load_balancer_cost{job=~\"$job\"})",
     "refId": "A"
    }
   ],
   "title": "LB Hourly Cost (total)",
   "description": "При NLB за Ingress метрика может быть пустой (0): OpenCost учитывает только Service type=LoadBalancer.",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "thresholds": { "steps": [{ "color": "green", "value": null }] },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
   "id": 9,
   "options": {
    "graphMode": "none",
    "reduceOptions": { "calcs": ["lastNotNull"] }
   },
   "targets": [
    {
     "expr": "sum(kubecost_load_balancer_cost{job=~\"$job\"}) * 730",
     "refId": "A"
    }
   ],
   "title": "LB Monthly Cost (total)",
   "description": "При NLB за Ingress метрика может быть пустой (0): OpenCost учитывает только Service type=LoadBalancer.",
   "type": "stat"
  },
  {
   "datasource": { "type": "prometheus", "uid": "$datasource" },
   "fieldConfig": {
    "defaults": {
     "custom": { "align": "auto" },
     "unit": "currencyRUB"
    }
   },
   "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
   "id": 10,
   "options": {
    "footer": { "enablePagination": true },
    "sortBy": [{ "desc": true, "displayName": "Hourly" }]
   },
   "targets": [
    {
     "expr": "sum(kubecost_load_balancer_cost{job=~\"$job\"}) by (namespace, service)",
     "format": "table",
     "instant": true,
     "refId": "A"
    }
   ],
   "title": "Load Balancer cost by namespace / service",
   "description": "При NLB за Ingress метрика может быть пустой (0): OpenCost учитывает только Service type=LoadBalancer.",
   "transformations": [
    { "id": "organize", "options": { "renameByName": { "namespace": "Namespace", "service": "Service", "Value": "Hourly (₽)" } } }
   ],
   "type": "table"
  }
 ],
 "schemaVersion": 39,
 "tags": ["opencost", "network", "loadbalancer"],
 "templating": {
  "list": [
   {
    "label": "Data source",
    "name": "datasource",
    "query": "prometheus",
    "type": "datasource"
   },
   {
    "datasource": { "type": "prometheus", "uid": "${datasource}" },
    "label": "Job",
    "name": "job",
    "query": "label_values(opencost_build_info, job)",
    "refresh": 2,
    "sort": 1,
    "type": "query"
   }
  ]
 },
 "time": { "from": "now-1h", "to": "now" },
 "timezone": "utc",
 "refresh": "1m",
 "title": "OpenCost / Network & Load Balancer",
 "uid": "opencost-network-lb",
 "version": 1
}
